# Secrets requis — copier ce fichier en .env et compléter les valeurs

# Master Key AES-GCM pour chiffrement des mots de passe (TP4)
# Générer avec : openssl rand -base64 32
APP_MASTER_KEY=

# JWT secret partagé avec Laravel (doit être identique des deux côtés)
# Minimum 32 caractères pour HS256
# Générer avec : openssl rand -base64 48
JWT_SECRET=

# MySQL
MYSQL_ROOT_PASSWORD=root
DB_PASSWORD=auth_pass