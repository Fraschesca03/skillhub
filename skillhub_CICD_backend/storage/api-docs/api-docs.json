        "/api/modules/{id}/terminer": {
            "post": {
                "tags": [
                    "Modules"
                ],
                "summary": "Marquer un module comme terminé (apprenant inscrit)",
                "description": "Marque un module comme terminé par l'apprenant connecté et recalcule sa progression.\n\nÉtapes :\n- Vérifie le JWT.\n- Refuse si l'utilisateur n'est pas apprenant (403).\n- Cherche le module (404 sinon).\n- Vérifie que l'apprenant est bien inscrit à la formation parent (403 sinon).\n- Si déjà terminé, renvoie un message + la progression actuelle (idempotent).\n- Sinon, ajoute la liaison module-user via la pivot avec termine=true.\n- Recalcule progression = (modules terminés / total modules) * 100, arrondi.\n- Met à jour inscription.progression.\n\nUtilise les modèles Module, Inscription et la relation user->modulesTermines().",
                "operationId": "eeb97b8a6ecada70172f015b1785d4b6",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "id du module",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Module terminé, progression renvoyée"
                    },
                    "403": {
                        "description": "Pas apprenant ou pas inscrit"
                    },
                    "404": {
                        "description": "Module introuvable"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
