# .env.example — Template de configuration
#
# Copier ce fichier vers .env et remplir les valeurs
# NE JAMAIS COMMITTER LE .env (contient les secrets)

#  Application Laravel 
APP_NAME=SkillHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

#  Base de donnees MySQL (partagee entre Laravel et Spring Boot) 
DB_DATABASE=skillhub
DB_USERNAME=skillhub
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

#  MongoDB (messages et activity logs) 
MONGO_DATABASE=skillhub_messages
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=

#  JWT (SECRET PARTAGE entre les 2 microservices) 
# Minimum 32 caracteres pour HS256
JWT_SECRET=
JWT_TTL=60

#  Spring Boot — Master Key AES-GCM (TP4) 
# Minimum 32 caracteres
APP_MASTER_KEY=

#  CORS 
APP_CORS_ORIGIN=http://localhost:5173

#  Nginx 
NGINX_HTTP_PORT=80